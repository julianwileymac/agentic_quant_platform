{
  "type": "record",
  "name": "MarketScannerV1",
  "namespace": "aqp.streaming.market",
  "doc": "Row from IBKR reqScannerSubscription. Emitted per ranked instrument per scan cycle.",
  "fields": [
    {"name": "ts_ns", "type": "long"},
    {"name": "scan_code", "type": "string", "doc": "e.g. TOP_PERC_GAIN, HOT_BY_VOLUME"},
    {"name": "instrument", "type": "string", "doc": "STK, STOCK.HK, FUT, etc."},
    {"name": "location_code", "type": ["null", "string"], "default": null},
    {"name": "rank", "type": "int"},
    {"name": "vt_symbol", "type": "string"},
    {"name": "con_id", "type": ["null", "long"], "default": null},
    {"name": "projection", "type": ["null", "string"], "default": null},
    {"name": "legs_str", "type": ["null", "string"], "default": null},
    {"name": "scanner_params_hash", "type": ["null", "string"], "default": null},
    {"name": "ingest_ts_ns", "type": "long"}
  ]
}
