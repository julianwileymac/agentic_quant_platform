{
  "type": "record",
  "name": "FeaturesIndicatorsV1",
  "namespace": "aqp.streaming.features",
  "doc": "Technical indicators computed by Flink windowing jobs. One record per symbol per window close.",
  "fields": [
    {"name": "ts_ns", "type": "long", "doc": "Window end epoch ns"},
    {"name": "window_start_ns", "type": "long"},
    {"name": "window_size_sec", "type": "int"},
    {"name": "vt_symbol", "type": "string"},
    {"name": "sma_5", "type": ["null", "double"], "default": null},
    {"name": "sma_10", "type": ["null", "double"], "default": null},
    {"name": "sma_20", "type": ["null", "double"], "default": null},
    {"name": "sma_50", "type": ["null", "double"], "default": null},
    {"name": "ema_12", "type": ["null", "double"], "default": null},
    {"name": "ema_26", "type": ["null", "double"], "default": null},
    {"name": "rsi_14", "type": ["null", "double"], "default": null},
    {"name": "macd_line", "type": ["null", "double"], "default": null},
    {"name": "macd_signal", "type": ["null", "double"], "default": null},
    {"name": "macd_histogram", "type": ["null", "double"], "default": null},
    {"name": "bb_upper", "type": ["null", "double"], "default": null},
    {"name": "bb_middle", "type": ["null", "double"], "default": null},
    {"name": "bb_lower", "type": ["null", "double"], "default": null},
    {"name": "atr_14", "type": ["null", "double"], "default": null},
    {"name": "vwap", "type": ["null", "double"], "default": null},
    {"name": "volume_sma_20", "type": ["null", "double"], "default": null},
    {"name": "obv", "type": ["null", "double"], "default": null},
    {"name": "price_lag_1", "type": ["null", "double"], "default": null},
    {"name": "price_lag_5", "type": ["null", "double"], "default": null},
    {"name": "price_lag_10", "type": ["null", "double"], "default": null},
    {"name": "volume_lag_1", "type": ["null", "double"], "default": null},
    {"name": "return_1", "type": ["null", "double"], "default": null},
    {"name": "return_5", "type": ["null", "double"], "default": null},
    {"name": "return_10", "type": ["null", "double"], "default": null},
    {"name": "close", "type": ["null", "double"], "default": null, "doc": "Last close observed in window"},
    {"name": "compute_ts_ns", "type": "long"}
  ]
}
