# ====================================================================
# Agentic Quant Platform — environment configuration
# Copy to .env and tweak. Everything is local-first; no external APIs.
# ====================================================================

# --- Runtime mode ---
AQP_ENV=dev                       # dev | staging | prod
AQP_LOG_LEVEL=INFO

# --- FinOps / cloud governance ---------------------------------------------
# These five tags are stamped on every Celery dispatch (via the
# before_task_publish signal in aqp.tasks.celery_app), every Kubernetes pod
# (via Kustomize commonLabels in deploy/k8s/base/), every MLflow run, and
# every progress emit. The Kyverno require-finops-tags ClusterPolicy in
# rpi_kubernetes denies any pod that doesn't declare them. Together this
# closes the cost-attribution chain from Grafana panel back to a single
# strategy_id / agent_run_id.
AQP_PROJECT_TAG=aqp-default
AQP_COST_CENTER=quant-research-01
AQP_OWNER=system-orchestrator
AQP_DATA_CLASSIFICATION=proprietary-alpha
# AQP_ENV (above) doubles as the FinOps "environment" label.

# --- Paths ---
AQP_DATA_DIR=./data
AQP_PARQUET_DIR=./data/parquet
AQP_MODELS_DIR=./data/models
AQP_CHROMA_DIR=./data/chroma
AQP_ARCTIC_URI=lmdb://./data/arctic

# --- LLM (Ollama + LiteLLM) ---
# Ollama runs natively on the host for GPU access.
AQP_OLLAMA_HOST=http://host.docker.internal:11434
AQP_LLM_MODEL=nemotron:latest
AQP_LLM_DEEP_MODEL=nemotron:latest
AQP_LLM_QUICK_MODEL=llama3.2:latest

# --- Data-pipeline Director (Nemotron by default) -----------------------
AQP_LLM_DIRECTOR_PROVIDER=ollama
AQP_LLM_DIRECTOR_MODEL=nemotron-3-nano:30b
AQP_LLM_DIRECTOR_TEMPERATURE=0.1
AQP_LLM_DIRECTOR_MAX_TOKENS=4096
AQP_LLM_DIRECTOR_ENABLED=true

# --- vLLM (optional) -------------------------------------------------------
AQP_VLLM_BASE_URL=
AQP_VLLM_API_KEY=
AQP_VLLM_DEFAULT_MODEL=nemotron

# --- vLLM compose profile knobs --------------------------------------------
VLLM_MODEL_ID=nvidia/Nemotron-4-Mini-Instruct
VLLM_SERVED_NAME=nemotron
VLLM_PORT=8002

# --- vLLM-FinGPT compose profile knobs -------------------------------------
FINGPT_BASE_MODEL=meta-llama/Llama-2-7b-hf
FINGPT_LORA_ID=fingpt-forecaster
FINGPT_LORA_PATH=FinGPT/fingpt-forecaster_dow30_llama2-7b_lora
VLLM_FINGPT_PORT=8003

HUGGINGFACE_HUB_TOKEN=
AQP_LLM_TEMPERATURE_DEEP=0.2
AQP_LLM_TEMPERATURE_QUICK=0.4
AQP_LLM_CONTEXT_WINDOW=32768

# --- Redis (broker + pub/sub + RAG / memory) ---
# Redis Stack is required for the hierarchical RAG (RediSearch HNSW).
# Standard Redis works too; the RAG falls back to a process-local index
# when RediSearch isn't available.
AQP_REDIS_URL=redis://localhost:6379/0
AQP_REDIS_PUBSUB_URL=redis://localhost:6379/1

# --- PostgreSQL (Execution Ledger) ---
AQP_POSTGRES_DSN=postgresql+psycopg2://aqp:aqp@localhost:5432/aqp
AQP_POSTGRES_ASYNC_DSN=postgresql+asyncpg://aqp:aqp@localhost:5432/aqp
AQP_POSTGRES_POOL_SIZE=10
AQP_POSTGRES_MAX_OVERFLOW=20
AQP_POSTGRES_POOL_TIMEOUT_SECONDS=30
AQP_POSTGRES_POOL_RECYCLE_SECONDS=1800

# --- Entity graph (Neo4j primary graph store) ---
AQP_GRAPH_STORE=neo4j
AQP_NEO4J_URI=bolt://localhost:7687
AQP_NEO4J_USER=neo4j
AQP_NEO4J_PASSWORD=aqpneo4j
AQP_NEO4J_DATABASE=neo4j
AQP_ENTITY_GRAPH_SYNC_ENABLED=true
AQP_ACTIVE_INSTRUMENT_CACHE_TTL_SECONDS=300
AQP_SERVICE_CONTROL_ENABLED=false
AQP_SERVICE_LOG_TAIL_LINES=200
# Polaris maps to host port 8183 in docker-compose.viz.yml; containers use polaris:8181.
AQP_POLARIS_BASE_URL=http://localhost:8183

# --- ChromaDB ---
AQP_CHROMA_HOST=localhost
AQP_CHROMA_PORT=8001

# --- Hierarchical RAG (Redis Stack / RediSearch) ---
# All RAG vectors + tag indexes live in the single Redis instance above.
# Default embedder is BGE-M3 (matches the Alpha-GPT paper); falls back
# to all-MiniLM-L6-v2 if BGE-M3 isn't installed and finally to a
# deterministic hash embedder for hermetic tests.
AQP_RAG_REDIS_PREFIX=aqp:rag
AQP_RAG_EMBEDDER=BAAI/bge-m3
AQP_RAG_RERANKER=BAAI/bge-reranker-base
AQP_RAG_DEFAULT_K=8
AQP_RAG_PER_LEVEL_K=5
AQP_RAG_RAPTOR_LEVELS=3
AQP_RAG_RAPTOR_K_MAX=8
AQP_RAG_AUDIT_ENABLED=true
AQP_RAG_COMPRESS_THRESHOLD=0.15
AQP_RAG_WORKING_MAX=64

# --- Agent runtime / observability ---
AQP_AGENT_RUN_ARTIFACT_DIR=./data/agent_runs
AQP_AGENT_DEFAULT_MAX_CALLS=20
AQP_AGENT_DEFAULT_MAX_COST_USD=2.0
AQP_AGENT_DECISION_LOG_PATH=./data/agent_runs/decision_log.md

# --- Regulatory data adapters (CFPB / FDA / USPTO) ---
# CFPB has no auth requirement; supply a User-Agent identifying you.
AQP_CFPB_USER_AGENT=aqp-research/0.1 (+https://github.com/)
AQP_CFPB_BASE_URL=https://www.consumerfinance.gov/data-research/consumer-complaints
AQP_CFPB_API_URL=https://www.consumerfinance.gov/data-research/consumer-complaints/search/api/v1
# openFDA: optional API key raises the rate limit (240 req/min vs 40).
AQP_FDA_API_KEY=
AQP_FDA_BASE_URL=https://api.fda.gov
# PatentsView REQUIRES an API key (https://patentsview.org/apis/keyrequest).
AQP_USPTO_API_KEY=
AQP_USPTO_PATENTSVIEW_URL=https://search.patentsview.org/api/v1
AQP_USPTO_PEDS_URL=https://ped.uspto.gov/api
AQP_USPTO_TSDR_URL=https://tsdrapi.uspto.gov/ts/cd/casestatus

# --- MLflow ---
AQP_MLFLOW_TRACKING_URI=http://localhost:5000
AQP_MLFLOW_EXPERIMENT=aqp-default

# --- ML engine major expansion (Alembic 0025) ---
# Per-bar prediction audit during AlphaBacktestExperiment runs.
# Capped to AQP_ML_PREDICTION_AUDIT_MAX_ROWS rows per run for safety.
AQP_ML_PREDICTION_AUDIT_ENABLED=false
AQP_ML_PREDICTION_AUDIT_MAX_ROWS=1000
# Native TF estimator path (separate from Keras 3 fallback). Requires the
# `ml-tensorflow` extra.
AQP_TF_NATIVE_ENABLED=false
# HuggingFace time-series transformer wrappers (PatchTST/Informer/etc).
# Requires the `ml-transformers` extra.
AQP_HF_TIMESERIES_ENABLED=false
AQP_HF_FINBERT_MODEL=ProsusAI/finbert
AQP_HF_TIMESERIES_MODEL=huggingface/time-series-transformer-tourism-monthly
# Max upload size for the interactive ML test workbench (MB).
AQP_ML_WORKBENCH_MAX_CSV_MB=20

# --- FastAPI ---
AQP_API_HOST=0.0.0.0
AQP_API_PORT=8000
AQP_API_RELOAD=true
# In-cluster API URL used by platform integrations such as DataHub OpenAPI ingestion.
# AQP_API_URL=http://api.aqp.svc.cluster.local:8000

# --- Solara UI (legacy, deprecated when Next.js webui ships) ---
AQP_UI_HOST=0.0.0.0
AQP_UI_PORT=8765

# --- Next.js webui ---
# Comma-separated list of allowed origins for the FastAPI CORS middleware.
AQP_WEBUI_CORS_ORIGINS=

# --- Visualization layer (Superset + Trino + Bokeh) ---
# Start with:
#   docker compose -f docker-compose.yml -f docker-compose.viz.yml --profile visualization up -d
AQP_SUPERSET_BASE_URL=http://localhost:8088
AQP_SUPERSET_PUBLIC_URL=http://localhost:8088
AQP_SUPERSET_USERNAME=admin
AQP_SUPERSET_PASSWORD=admin
AQP_SUPERSET_PROVIDER=db
AQP_SUPERSET_GUEST_USERNAME=aqp_guest
AQP_SUPERSET_GUEST_FIRST_NAME=AQP
AQP_SUPERSET_GUEST_LAST_NAME=Guest
AQP_SUPERSET_DEFAULT_DASHBOARD_UUID=
AQP_TRINO_URI=trino://trino@localhost:8080/iceberg
AQP_TRINO_CATALOG=iceberg
AQP_TRINO_SCHEMA=aqp
# Optional HTTP base for GET /v1/info probes (defaults to host:port from AQP_TRINO_URI).
# On the host with Trino published on 8080: AQP_TRINO_HTTP_URL=http://localhost:8080
# With ``docker compose -f docker-compose.yml -f docker-compose.viz.yml --profile visualization``,
# api/worker override this to http://trino:8080 automatically.
# AQP_TRINO_HTTP_URL=
POLARIS_CATALOG=quickstart_catalog
POLARIS_CLIENT_ID=root
POLARIS_CLIENT_SECRET=s3cr3t

# --- Iceberg + Polaris bootstrap manager -------------------------------------
# Toggles the AQP IcebergBootstrapManager that creates the catalog, principal,
# principal-role, catalog-role, and grants on first start.
AQP_ICEBERG_AUTO_BOOTSTRAP=true
AQP_ICEBERG_CATALOG_WAREHOUSE_NAME=quickstart_catalog
AQP_ICEBERG_CATALOG_STORAGE_TYPE=S3
AQP_ICEBERG_DEFAULT_BASE_LOCATION=s3://aqp-iceberg/quickstart_catalog
AQP_ICEBERG_PRINCIPAL_NAME=aqp_runtime
AQP_ICEBERG_PRINCIPAL_ROLE=aqp_runtime_role
AQP_ICEBERG_CATALOG_ROLE=aqp_runtime_catalog_role
AQP_ICEBERG_CATALOG_PRIVILEGE=CATALOG_MANAGE_CONTENT
AQP_POLARIS_REALM=POLARIS
AQP_POLARIS_CLIENT_ID=root
AQP_POLARIS_CLIENT_SECRET=s3cr3t
AQP_BOOTSTRAP_STATE_DIR=./data/bootstrap

# --- Trino service-manager controls ------------------------------------------
AQP_TRINO_ADMIN_USER=aqp
AQP_TRINO_ADMIN_SOURCE=aqp-service-manager
# The visualization profile points API/worker/Trino at Polaris automatically.
# For non-compose clients, uncomment these (Polaris maps to host port 8183 in docker-compose.viz.yml
# so it can run alongside iceberg-rest on 8181):
# AQP_ICEBERG_REST_URI=http://localhost:8183/api/catalog
# AQP_ICEBERG_REST_CREDENTIAL=${POLARIS_CLIENT_ID}:${POLARIS_CLIENT_SECRET}
# AQP_ICEBERG_REST_TOKEN=
# AQP_ICEBERG_REST_OAUTH2_SERVER_URI=
# AQP_ICEBERG_REST_SCOPE=PRINCIPAL_ROLE:ALL
# Required for Apache Polaris (viz profile): realm header on PyIceberg REST calls.
# AQP_ICEBERG_REST_EXTRA_PROPERTIES_JSON={"header.Polaris-Realm":"POLARIS"}
AQP_VISUALIZATION_CACHE_DIR=./data/visualizations/cache
AQP_VISUALIZATION_CACHE_TTL_SECONDS=3600
AQP_VISUALIZATION_DEFAULT_LIMIT=1000
# Two-tier Bokeh cache: both | redis | file
AQP_VISUALIZATION_CACHE_BACKEND=both
AQP_VISUALIZATION_BUNDLE_DIR=./data/visualizations/bundles
# DataHub Superset connector ingestion (off by default; flips on with AQP_DATAHUB_GMS_URL set).
AQP_DATAHUB_SUPERSET_SYNC_ENABLED=false
NEXT_PUBLIC_SUPERSET_URL=http://localhost:8088
SUPERSET_SECRET_KEY=change-me-local-superset-secret
SUPERSET_GUEST_TOKEN_JWT_SECRET=change-me-local-superset-guest-secret

# --- Celery ---
AQP_CELERY_CONCURRENCY=4
AQP_CELERY_GPU_CONCURRENCY=1

# --- Risk defaults ---
AQP_RISK_MAX_POSITION_PCT=0.20
AQP_RISK_MAX_DAILY_LOSS_PCT=0.03
AQP_RISK_MAX_DRAWDOWN_PCT=0.15
AQP_RISK_KILL_SWITCH_KEY=aqp:kill_switch

# --- Data universe defaults ---
AQP_DEFAULT_UNIVERSE=SPY,AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,META,JPM,JNJ
AQP_DEFAULT_START=2020-01-01
AQP_DEFAULT_END=2024-12-31
AQP_ALPHA_VANTAGE_ENABLED=true
AQP_ALPHA_VANTAGE_API_KEY=
AQP_ALPHA_VANTAGE_API_KEY_FILE=
AQP_ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
AQP_ALPHA_VANTAGE_RPM_LIMIT=75
AQP_ALPHA_VANTAGE_RPS_LIMIT=8
AQP_ALPHA_VANTAGE_DAILY_LIMIT=0
AQP_ALPHA_VANTAGE_TIMEOUT_SECONDS=30
AQP_ALPHA_VANTAGE_MAX_RETRIES=5
AQP_ALPHA_VANTAGE_CACHE_BACKEND=memory
AQP_ALPHA_VANTAGE_CACHE_MAX_ENTRIES=512
AQP_ALPHA_VANTAGE_RAPIDAPI=false
AQP_ALPHA_VANTAGE_INTRADAY_INTERVAL=1min
AQP_ALPHA_VANTAGE_INTRADAY_LOOKBACK_MONTHS=36
AQP_ALPHA_VANTAGE_INTRADAY_BATCH_SIZE=25
AQP_ALPHA_VANTAGE_INTRADAY_RUN_GUARD_MAX_STARTS=3
AQP_ALPHA_VANTAGE_INTRADAY_RUN_GUARD_WINDOW_SECONDS=900
AQP_ALPHA_VANTAGE_INTRADAY_MANIFEST_DIR=./data/alpha_vantage/intraday_components
AQP_ALPHA_VANTAGE_INTRADAY_NAMESPACE=aqp_alpha_vantage
AQP_ALPHA_VANTAGE_INTRADAY_TABLE=time_series_intraday

AQP_DATAHUB_GMS_URL=
AQP_DATAHUB_TOKEN=
AQP_DATAHUB_ENV=PROD
AQP_AIRBYTE_ENABLED=false
# When true: set AQP_AIRBYTE_WORKSPACE_ID (Airbyte UI) and AQP_AIRBYTE_AUTH_TOKEN (Settings > Access Management).
# The visualization compose profile enables a local Airbyte-compatible dev server at http://airbyte-server:8001
# and publishes it to the host at http://localhost:8002.
# In Docker Desktop, point at Airbyte on the host, e.g. http://host.docker.internal:8001
# In Kubernetes, use the in-cluster server URL (default below).
AQP_AIRBYTE_BASE_URL=http://airbyte-server.elt.svc.cluster.local:8001
AQP_AIRBYTE_API_URL=
AQP_AIRBYTE_WORKSPACE_ID=
AQP_AIRBYTE_AUTH_TOKEN=
AQP_AIRBYTE_REQUEST_TIMEOUT_SECONDS=30
AQP_AIRBYTE_POLL_INTERVAL_SECONDS=5
AQP_AIRBYTE_SYNC_TIMEOUT_SECONDS=3600
AQP_AIRBYTE_DEFAULT_DESTINATION=destination-s3-minio
AQP_AIRBYTE_DEFAULT_NAMESPACE=aqp_airbyte
AQP_AIRBYTE_EMBEDDED_CACHE_DIR=./data/airbyte/cache
AQP_AIRBYTE_STAGING_ROOT=s3://aqp-datasets/airbyte
AQP_AIRBYTE_DATAHUB_SYNC_ENABLED=true

# --- dbt foundation (local DuckDB modeling project) ---
AQP_DBT_PROJECT_DIR=./data/dbt/aqp
AQP_DBT_PROFILES_DIR=./data/dbt
AQP_DBT_DUCKDB_PATH=./data/dbt/aqp.duckdb
AQP_DBT_TARGET=dev
AQP_DBT_GENERATED_SCHEMA=aqp_generated
AQP_DBT_GENERATED_TAG=aqp_generated
AQP_DBT_ARTIFACT_RETENTION=25
AQP_DBT_COMMAND_TIMEOUT_SECONDS=900
AQP_DBT_EXPORT_DIR=./data/dbt/exports

AQP_MARKET_BARS_PROVIDER=auto
AQP_FUNDAMENTALS_PROVIDER=auto
AQP_UNIVERSE_PROVIDER=managed_snapshot
AQP_MANAGED_UNIVERSE_LIMIT=200
AQP_LOCAL_DATA_ROOTS=

# --- Paper trading ---
AQP_PAPER_DEFAULT_HEARTBEAT_SECONDS=30
AQP_PAPER_STATE_FLUSH_EVERY_BARS=10

# --- Alpaca ---
AQP_ALPACA_API_KEY=
AQP_ALPACA_SECRET_KEY=
AQP_ALPACA_PAPER=true
AQP_ALPACA_BASE_URL=

# --- Interactive Brokers ---
AQP_IBKR_HOST=127.0.0.1
AQP_IBKR_PORT=7497
AQP_IBKR_CLIENT_ID=1

# --- Tradier ---
AQP_TRADIER_TOKEN=
AQP_TRADIER_BASE_URL=https://sandbox.tradier.com/v1
AQP_TRADIER_ACCOUNT_ID=

# --- OpenTelemetry ---
AQP_OTEL_ENDPOINT=
AQP_OTEL_SERVICE_NAME=aqp
AQP_OTEL_SAMPLE_RATIO=1.0
AQP_OTEL_PROTOCOL=grpc

# --- Kafka ---
AQP_KAFKA_BOOTSTRAP=localhost:9092
AQP_KAFKA_CLIENT_ID=aqp
AQP_KAFKA_COMPRESSION=zstd
AQP_KAFKA_ACKS=all
AQP_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
AQP_KAFKA_SASL_MECHANISM=
AQP_KAFKA_SASL_USERNAME=
AQP_KAFKA_SASL_PASSWORD=
AQP_KAFKA_TOPIC_PREFIX=
AQP_KAFKA_CONSUMER_GROUP=aqp-live

# --- Kafka admin (Data layer expansion) ---
# Optional overrides for the native admin client. Leave blank to inherit
# from the regular AQP_KAFKA_* settings above.
AQP_KAFKA_ADMIN_BOOTSTRAP=
AQP_KAFKA_ADMIN_SECURITY_PROTOCOL=
AQP_KAFKA_ADMIN_SASL_MECHANISM=
AQP_KAFKA_ADMIN_SASL_USERNAME=
AQP_KAFKA_ADMIN_SASL_PASSWORD=
# Apicurio (Confluent ccompat-shimmed) URL — used by /streaming/kafka/schema-registry
AQP_KAFKA_ADMIN_SCHEMA_REGISTRY_URL=
AQP_SCHEMA_REGISTRY_URL=

# --- Flink (Data layer expansion) ---
AQP_FLINK_REST_URL=
AQP_FLINK_NAMESPACE=data-services
AQP_FLINK_SESSION_CLUSTER_NAME=flink-session
AQP_FLINK_SAVEPOINT_DIR=s3://flink-savepoints
AQP_FLINK_FACTOR_JAR_URI=s3://flink-jobs/factor_compute.jar
AQP_FLINK_FACTOR_ENTRY_CLASS=io.aqp.flink.factor.FactorJob

# --- rpi_kubernetes management API proxy ---
AQP_CLUSTER_MGMT_URL=
AQP_CLUSTER_MGMT_TOKEN=

# --- Streaming producers ---
AQP_STREAMING_PRODUCERS_NAMESPACE=data-services

# --- Streaming ingester ---
AQP_STREAM_UNIVERSE=
AQP_STREAM_CONFIG_FILE=
AQP_STREAM_MARKET_DATA_TYPE=3
AQP_STREAM_SCANNER_INTERVAL_SEC=300
AQP_STREAM_SCANNER_ENABLED=false
AQP_STREAM_INCLUDE_QUOTES=true
AQP_STREAM_INCLUDE_TRADES=true
AQP_STREAM_INCLUDE_BARS=true
AQP_STREAM_METRICS_PORT=9300
AQP_STREAM_HEALTH_PORT=9301

AQP_ALPACA_FEED=iex

# ====================================================================
# Data plane expansion (Phase 2-4 of the data plane expansion plan).
# ====================================================================

# --- FRED ---
AQP_FRED_API_KEY=
AQP_FRED_CACHE_TTL_SECONDS=3600

# --- SEC EDGAR ---
AQP_SEC_EDGAR_IDENTITY=
AQP_SEC_FILING_CACHE_DIR=./data/sec_cache

# --- GDelt GKG 2.0 ---
AQP_GDELT_MANIFEST_URL=http://data.gdeltproject.org/gkg/index.html
AQP_GDELT_PARQUET_SUBDIR=gdelt
AQP_GDELT_SUBJECT_FILTER_ONLY=true

# --- GDelt BigQuery federation ---
AQP_GDELT_BIGQUERY_PROJECT=
AQP_GDELT_BIGQUERY_TABLE=gdelt-bq.gdeltv2.gkg

# ====================================================================
# Iceberg catalog — persistent on the host drive
# ====================================================================
AQP_ICEBERG_WAREHOUSE=/warehouse/iceberg
AQP_ICEBERG_STAGING_DIR=/warehouse/staging
AQP_ICEBERG_NAMESPACE_DEFAULT=aqp
AQP_ICEBERG_CATALOG_NAME=aqp
AQP_ICEBERG_MAX_ROWS_PER_DATASET=5000000
AQP_ICEBERG_MAX_FILES_PER_DATASET=2000
# AQP_ICEBERG_REST_URI=http://iceberg-rest:8181
# AQP_ICEBERG_S3_WAREHOUSE=s3://aqp-iceberg/
# AQP_S3_ENDPOINT_URL=http://minio:9000
# AQP_S3_ACCESS_KEY=aqpminio
# AQP_S3_SECRET_KEY=aqpminiosecret
# AQP_S3_REGION=us-east-1

# rpi_kubernetes shared lakehouse profile:
# AQP_MLFLOW_TRACKING_URI=http://mlflow.ml-platform.svc.cluster.local:5000
# AQP_ICEBERG_REST_URI=http://datahub-datahub-gms.data-services.svc.cluster.local:8080/iceberg
# AQP_ICEBERG_S3_WAREHOUSE=s3://iceberg-warehouse/aqp/
# AQP_S3_ENDPOINT_URL=http://minio.data-services.svc.cluster.local:9000
# AQP_S3_REGION=us-east-1
# AQP_MINIO_ENDPOINT_URL=http://minio.data-services.svc.cluster.local:9000
# AQP_MINIO_ARTIFACTS_BUCKET=aqp-artifacts
# AQP_MINIO_DATASETS_BUCKET=aqp-datasets

# ====================================================================
# Data fabric expansion — engine, compute, source library, profiling,
# entity registry, Dagster code location, DataHub bidirectional sync.
# ====================================================================

# --- Engine + compute backends -----------------------------------------
AQP_COMPUTE_BACKEND_DEFAULT=auto       # auto | local | dask | ray
AQP_COMPUTE_LOCAL_TO_DASK_ROWS=1000000
AQP_COMPUTE_LOCAL_TO_RAY_ROWS=25000000
AQP_COMPUTE_LOCAL_TO_DASK_BYTES=268435456
AQP_COMPUTE_LOCAL_TO_RAY_BYTES=8589934592
AQP_DASK_SCHEDULER_ADDRESS=
AQP_DASK_N_WORKERS=2
AQP_DASK_THREADS_PER_WORKER=2
AQP_RAY_INIT_KWARGS_JSON=
AQP_ENGINE_DEFAULT_CHUNK_ROWS=50000
AQP_ENGINE_MAX_CONCURRENT_PIPELINES=2
AQP_ENGINE_PIPELINE_TIMEOUT_SECONDS=3600

# --- Source library defaults -------------------------------------------
AQP_FETCHER_DEFAULT_CHUNK_ROWS=50000
AQP_FETCHER_MAX_CONCURRENT=4
AQP_FETCHER_DEFAULT_TIMEOUT_SECONDS=120
AQP_FETCHER_MAX_RETRIES=5
AQP_FETCHER_USER_AGENT=aqp-fetcher/1.0 (+https://github.com/)
AQP_FINANCE_DATABASE_REPO=https://raw.githubusercontent.com/JerBouma/FinanceDatabase/main/financedatabase/compression
AQP_POLYGON_API_KEY=
AQP_TIINGO_API_KEY=
AQP_QUANDL_API_KEY=
AQP_COINGECKO_API_KEY=
AQP_AKSHARE_ENABLED=false

# --- Profile cache -----------------------------------------------------
AQP_PROFILE_CACHE_TTL_SECONDS=3600
AQP_PROFILE_CACHE_PREFIX=aqp:profile
AQP_PROFILE_TOPK=10
AQP_PROFILE_DISTINCT_SAMPLE_ROWS=200000
AQP_PROFILE_DEFAULT_ENGINE=auto

# --- Entity registry ---------------------------------------------------
AQP_ENTITY_EXTRACTION_ENABLED=true
AQP_ENTITY_LLM_ENRICHMENT_ENABLED=false
AQP_ENTITY_LLM_PROVIDER=
AQP_ENTITY_LLM_MODEL=
AQP_ENTITY_MAX_NEIGHBORS=64
AQP_ENTITY_DEDUP_SIMILARITY_THRESHOLD=0.85

# --- Dagster code location ---------------------------------------------
AQP_DAGSTER_HOME=./data/dagster_home
AQP_DAGSTER_GRPC_HOST=0.0.0.0
AQP_DAGSTER_GRPC_PORT=4000
# The visualization compose profile sets these to http://dagster-webserver:3001[/graphql].
AQP_DAGSTER_WEBSERVER_URL=
AQP_DAGSTER_GRAPHQL_URL=
AQP_DAGSTER_CODE_LOCATION=aqp
AQP_DAGSTER_MODULE_PATH=aqp.dagster.definitions
AQP_AQP_API_URL_INTERNAL=http://api.aqp.svc.cluster.local:8000
AQP_AQP_API_TOKEN=

# --- DataHub bidirectional sync ----------------------------------------
AQP_DATAHUB_SYNC_ENABLED=false
AQP_DATAHUB_SYNC_DIRECTION=push        # push | pull | bidirectional
AQP_DATAHUB_SYNC_INTERVAL_SECONDS=900
AQP_DATAHUB_PLATFORM=iceberg
AQP_DATAHUB_PLATFORM_INSTANCE=agentic-quant-platform
AQP_DATAHUB_EXTERNAL_PLATFORMS=mlflow,kafka,grafana
