# ====================================================================
# Agentic Quant Platform — environment configuration
# Copy to .env and tweak. Everything is local-first; no external APIs.
# ====================================================================

# --- Runtime mode ---
AQP_ENV=dev                       # dev | staging | prod
AQP_LOG_LEVEL=INFO

# --- Paths ---
AQP_DATA_DIR=./data
AQP_PARQUET_DIR=./data/parquet
AQP_MODELS_DIR=./data/models
AQP_CHROMA_DIR=./data/chroma
AQP_ARCTIC_URI=lmdb://./data/arctic

# --- LLM (Ollama + LiteLLM) ---
# Ollama runs natively on the host for GPU access.
AQP_OLLAMA_HOST=http://host.docker.internal:11434
AQP_LLM_MODEL=nemotron:latest
AQP_LLM_DEEP_MODEL=nemotron:latest
AQP_LLM_QUICK_MODEL=llama3.2:latest
AQP_LLM_TEMPERATURE_DEEP=0.2
AQP_LLM_TEMPERATURE_QUICK=0.4
AQP_LLM_CONTEXT_WINDOW=32768

# --- Redis (broker + pub/sub) ---
AQP_REDIS_URL=redis://localhost:6379/0
AQP_REDIS_PUBSUB_URL=redis://localhost:6379/1

# --- PostgreSQL (Execution Ledger) ---
AQP_POSTGRES_DSN=postgresql+psycopg2://aqp:aqp@localhost:5432/aqp
AQP_POSTGRES_ASYNC_DSN=postgresql+asyncpg://aqp:aqp@localhost:5432/aqp

# --- ChromaDB ---
AQP_CHROMA_HOST=localhost
AQP_CHROMA_PORT=8001

# --- MLflow ---
AQP_MLFLOW_TRACKING_URI=http://localhost:5000
AQP_MLFLOW_EXPERIMENT=aqp-default

# --- FastAPI ---
AQP_API_HOST=0.0.0.0
AQP_API_PORT=8000
AQP_API_RELOAD=true

# --- Solara UI (legacy, deprecated when Next.js webui ships) ---
AQP_UI_HOST=0.0.0.0
AQP_UI_PORT=8765

# --- Next.js webui ---
# Comma-separated list of allowed origins for the FastAPI CORS middleware.
# Leave empty to keep the legacy "*" behaviour (any origin allowed).
# Example: AQP_WEBUI_CORS_ORIGINS=http://localhost:3000,https://aqp.example.com
AQP_WEBUI_CORS_ORIGINS=

# --- Celery ---
AQP_CELERY_CONCURRENCY=4
AQP_CELERY_GPU_CONCURRENCY=1

# --- Risk defaults ---
AQP_RISK_MAX_POSITION_PCT=0.20
AQP_RISK_MAX_DAILY_LOSS_PCT=0.03
AQP_RISK_MAX_DRAWDOWN_PCT=0.15
AQP_RISK_KILL_SWITCH_KEY=aqp:kill_switch

# --- Data universe defaults ---
AQP_DEFAULT_UNIVERSE=SPY,AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,META,JPM,JNJ
AQP_DEFAULT_START=2020-01-01
AQP_DEFAULT_END=2024-12-31
# Alpha Vantage key used by bars/fundamentals/universe/provider flows.
AQP_ALPHA_VANTAGE_ENABLED=true
AQP_ALPHA_VANTAGE_API_KEY=
AQP_ALPHA_VANTAGE_API_KEY_FILE=
AQP_ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
AQP_ALPHA_VANTAGE_RPM_LIMIT=75
AQP_ALPHA_VANTAGE_DAILY_LIMIT=0
AQP_ALPHA_VANTAGE_TIMEOUT_SECONDS=30
AQP_ALPHA_VANTAGE_MAX_RETRIES=5
AQP_ALPHA_VANTAGE_CACHE_BACKEND=memory
AQP_ALPHA_VANTAGE_CACHE_MAX_ENTRIES=512
AQP_ALPHA_VANTAGE_RAPIDAPI=false
# Provider policy:
# - auto: AV primary when configured, otherwise yfinance.
# - alpha_vantage: AV first, then yfinance fallback.
# - yfinance: force yfinance.
AQP_MARKET_BARS_PROVIDER=auto
AQP_FUNDAMENTALS_PROVIDER=auto
# Universe source:
# - managed_snapshot: use Instrument snapshot first, then default universe fallback.
# - config: always use AQP_DEFAULT_UNIVERSE.
AQP_UNIVERSE_PROVIDER=managed_snapshot
AQP_MANAGED_UNIVERSE_LIMIT=200

# Comma-separated list of extra Parquet roots merged into the DuckDB view.
# Useful to point at vendor exports on a mounted drive, e.g.:
#   AQP_LOCAL_DATA_ROOTS=/mnt/quant-data/daily,/mnt/quant-data/minute
AQP_LOCAL_DATA_ROOTS=

# --- Paper trading ---
AQP_PAPER_DEFAULT_HEARTBEAT_SECONDS=30
AQP_PAPER_STATE_FLUSH_EVERY_BARS=10

# --- Alpaca (pip install -e ".[alpaca]") ---
# Paper keys from https://app.alpaca.markets/paper/dashboard/overview
AQP_ALPACA_API_KEY=
AQP_ALPACA_SECRET_KEY=
AQP_ALPACA_PAPER=true
AQP_ALPACA_BASE_URL=

# --- Interactive Brokers (pip install -e ".[ibkr]") ---
# Requires a running TWS or IB Gateway. 7497=paper, 7496=live.
AQP_IBKR_HOST=127.0.0.1
AQP_IBKR_PORT=7497
AQP_IBKR_CLIENT_ID=1

# --- Tradier (REST template; token from developer.tradier.com) ---
AQP_TRADIER_TOKEN=
AQP_TRADIER_BASE_URL=https://sandbox.tradier.com/v1
AQP_TRADIER_ACCOUNT_ID=

# --- OpenTelemetry (pip install -e ".[otel]") ---
# Leave blank to disable tracing. Default OTLP/gRPC port is 4317.
AQP_OTEL_ENDPOINT=
AQP_OTEL_SERVICE_NAME=aqp
AQP_OTEL_SAMPLE_RATIO=1.0
AQP_OTEL_PROTOCOL=grpc

# --- Kafka (pip install -e ".[streaming]") ---
# On the rpi_kubernetes cluster:
#   AQP_KAFKA_BOOTSTRAP=trading-kafka-kafka-bootstrap.data-services.svc.cluster.local:9092
AQP_KAFKA_BOOTSTRAP=localhost:9092
AQP_KAFKA_CLIENT_ID=aqp
AQP_KAFKA_COMPRESSION=zstd
AQP_KAFKA_ACKS=all
AQP_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
AQP_KAFKA_SASL_MECHANISM=
AQP_KAFKA_SASL_USERNAME=
AQP_KAFKA_SASL_PASSWORD=
AQP_KAFKA_TOPIC_PREFIX=
AQP_KAFKA_CONSUMER_GROUP=aqp-live

# --- Streaming ingester (aqp-stream-ingest) ---
# Leave AQP_STREAM_UNIVERSE empty to reuse AQP_DEFAULT_UNIVERSE.
AQP_STREAM_UNIVERSE=
AQP_STREAM_CONFIG_FILE=
# IBKR reqMarketDataType: 1 live, 2 frozen, 3 delayed, 4 delayed-frozen.
AQP_STREAM_MARKET_DATA_TYPE=3
AQP_STREAM_SCANNER_INTERVAL_SEC=300
AQP_STREAM_SCANNER_ENABLED=false
AQP_STREAM_INCLUDE_QUOTES=true
AQP_STREAM_INCLUDE_TRADES=true
AQP_STREAM_INCLUDE_BARS=true
AQP_STREAM_METRICS_PORT=9300
AQP_STREAM_HEALTH_PORT=9301

# Alpaca streaming feed: iex (free) | sip (paid) | delayed_sip (15-min).
AQP_ALPACA_FEED=iex

# ====================================================================
# Data plane expansion (Phase 2-4 of the data plane expansion plan).
# Each source has an optional pip extra; install what you need.
# ====================================================================

# --- FRED (pip install -e ".[fred]") ---
# Get a key from https://fredaccount.stlouisfed.org/apikeys
AQP_FRED_API_KEY=
AQP_FRED_CACHE_TTL_SECONDS=3600

# --- SEC EDGAR (pip install -e ".[sec]") ---
# edgartools REQUIRES an identity string "Name email@example.com" to
# respect the SEC fair-use guidance — the adapter refuses to issue
# requests when this is empty.
AQP_SEC_EDGAR_IDENTITY=
AQP_SEC_FILING_CACHE_DIR=./data/sec_cache

# --- GDelt GKG 2.0 (pip install -e ".[gdelt]") ---
# Manifest lives at http://data.gdeltproject.org/gkg/index.html.
AQP_GDELT_MANIFEST_URL=http://data.gdeltproject.org/gkg/index.html
# Sub-dir under AQP_PARQUET_DIR for the partitioned GDelt lake.
AQP_GDELT_PARQUET_SUBDIR=gdelt
# Keep only GKG rows whose organizations match a registered Instrument.
# Setting this to false keeps every row (scales to ~2.5 TB/year).
AQP_GDELT_SUBJECT_FILTER_ONLY=true

# --- GDelt BigQuery federation (pip install -e ".[gdelt-bq]") ---
# Requires GOOGLE_APPLICATION_CREDENTIALS or default app credentials.
AQP_GDELT_BIGQUERY_PROJECT=
AQP_GDELT_BIGQUERY_TABLE=gdelt-bq.gdeltv2.gkg
