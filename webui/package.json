{
  "name": "aqp-webui",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js 15 frontend for the Agentic Quant Platform",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "gen:api": "openapi-typescript ../data/openapi.json -o lib/api/generated/schema.d.ts"
  },
  "dependencies": {
    "@ant-design/charts": "^2.2.0",
    "@ant-design/cssinjs": "^1.21.0",
    "@ant-design/icons": "^5.5.1",
    "@ant-design/nextjs-registry": "^1.0.0",
    "@hookform/resolvers": "^3.9.0",
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-devtools": "^5.59.0",
    "@xyflow/react": "^12.3.0",
    "ag-grid-community": "^32.3.0",
    "ag-grid-react": "^32.3.0",
    "antd": "^5.21.0",
    "dayjs": "^1.11.13",
    "next": "15.0.0",
    "openapi-fetch": "^0.13.0",
    "react": "19.0.0-rc-69d4b800-20241021",
    "react-dom": "19.0.0-rc-69d4b800-20241021",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^9.0.1",
    "recharts": "^2.13.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.7.0",
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9.12.0",
    "eslint-config-next": "15.0.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1"
  },
  "optionalDependencies": {
    "react-financial-charts": "^2.0.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
